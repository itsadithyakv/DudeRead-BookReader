# DudeReads environment

# Google Drive sync (used by the Tauri backend)
DUDEREADER_GOOGLE_CLIENT_ID=
DUDEREADER_GOOGLE_CLIENT_SECRET=

# Optional backend for user profiles (MongoDB / Mongoose)
# Create a server that uses these values; they are NOT used by the app yet.
MONGODB_URI=
MONGODB_DB=dudereader
MONGODB_PROFILE_COLLECTION=profiles

# Frontend API base if you add a profile/analytics server
VITE_API_BASE_URL=
